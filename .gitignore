# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Android local secrets / build
android/local.properties
android/keystore.properties
android/app/release/
android/.gradle/
android/app/build/
android/build/

# fastlane / Google Play secrets + outputs (kept outside android/ so
# `expo prebuild --clean` does not wipe them)
vendor/bundle/
fastlane/play-store-service-account.json
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/
fastlane/README.md
**/*service-account*.json

# typescript
*.tsbuildinfo
