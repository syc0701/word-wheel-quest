{
  "expo": {
    "name": "Word Wheel Quest",
    "slug": "word-wheel-quest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/bg_image/deep_sea.png",
      "resizeMode": "cover",
      "backgroundColor": "#031525"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puzint.wordwheel.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.puzint.wordwheel.app"
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-apple-authentication",
      "expo-audio"
    ]
  }
}
